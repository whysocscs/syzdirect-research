# Copy this file to configs/run_case.env and adjust values for your machine.
# Inline environment variables still override values from the loaded config.

export DATASET_KIND="known-bugs"
export MODE="agent-loop"
export BUDGET_HOURS="1"
export REPETITIONS="1"

# Keep runtime/build artifacts on the Linux filesystem, not under /mnt/c.
export OUTPUT_ROOT="$HOME/syzdirect-runtime"

export VM_CPU="1"
export KERNEL_CMDLINE_EXTRA="maxcpus=1 net.ifnames=0 biosdevname=0"

# Optional: provide sudo non-interactively for image/KVM setup.
# export SUDO_PASSWORD="your-sudo-password"

# Continuous watcher settings.
export AGENT_CHECK_INTERVAL="600"
export AGENT_MAX_INTERVENTIONS="5"

# Optional: enable opencode-backed watcher decisions.
export LLM_DECISION_CMD="python3 /mnt/c/Users/Administrator/syzdirect-research/scripts/opencode_llm_decider.py"
export OPENCODE_MODEL="openai/gpt-5"
export OPENCODE_VARIANT="high"

# Optional: provider-specific opencode knobs.
# export OPENCODE_AGENT="default"
# export OPENCODE_DIR="/mnt/c/Users/Administrator/syzdirect-research"
