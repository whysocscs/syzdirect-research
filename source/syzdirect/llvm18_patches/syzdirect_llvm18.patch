+void ModuleSanitizerCoverage::loadDistanceInfo() {
+  StringRef DistanceDir = StringRef(Options.DistanceDir);
+  if (DistanceDir.empty())
+    return;
+  std::error_code EC;
+  for (auto It = sys::fs::directory_iterator(DistanceDir, EC),
+          End = sys::fs::directory_iterator();
+      !EC && It != End; It.increment(EC)) {
+    StringRef filePath = It->path();
+    if(sys::fs::is_regular_file(filePath) && filePath.ends_with(".dist")) {
+      StringRef relatePathSig = filePath.substr(DistanceDir.size(), filePath.size()-DistanceDir.size()-5);
+      if (relatePathSig.starts_with("/")) {
+        relatePathSig = relatePathSig.substr(1);
+      }
+      std::string line;
+      StringRef lineStrRef;
+      std::ifstream distanceFile(filePath.str());
+      if (distanceFile.is_open()) {
+        while (!distanceFile.eof()) {
+          std::getline(distanceFile, line);
+          strip(line);
+          if (line.empty()) continue;
+          lineStrRef = StringRef(line);
+          SmallVector<StringRef> splitRes;
+          SplitString(lineStrRef, splitRes, " ");
+          if (splitRes.size() != 3) {
+            errs() << "split error when parsing distance files" << "\n";
+            exit(-1);
+          }
+          StringRef funcName = splitRes[0];
+          unsigned int blockIdx = std::stoi(splitRes[1].str());
+          unsigned int blockDistance = std::stoi(splitRes[2].str());
+          std::string relatePathSigStr = relatePathSig.str();
+          std::string funcNameStr = funcName.str();
+          BlockDistanceInfo[relatePathSigStr][funcNameStr][blockIdx] = blockDistance;
+        }
+      }
+    }
+  }
+}
