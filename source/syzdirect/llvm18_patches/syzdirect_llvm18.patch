+void strip(std::string &str) {
+  if  (str.length() != 0) {
+    auto w = std::string(" ");
+    auto n = std::string("\n");
+    auto r = std::string("\t");
+    auto t = std::string("\r");
+    auto z = std::string("\x00");
+    auto v = std::string(1 ,str.front());
+    while((v == w) || (v==t) || (v==r) || (v==n) || (v==z)) {
+        str.erase(str.begin());
+        v = std::string(1 ,str.front());
+    }
+    v = std::string(1 , str.back());
+    while((v ==w) || (v==t) || (v==r) || (v==n) || (v==z)) {
+        str.erase(str.end() - 1 );
+        v = std::string(1 , str.back());
+    }
+  }
+}
